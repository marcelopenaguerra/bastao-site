# Postgres (Supabase) - mesma instância usada pelo app Streamlit atual
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/postgres

# Chave para assinar cookies de sessão (gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=troque-esta-chave

# Ambiente: local | production
ENV=local
